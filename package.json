{
  "name": "flownotes",
  "displayName": "FlowNotes",
  "description": "A simple extension for taking quick notes Resources in VSCode",
  "version": "0.0.3",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "flownotes",
          "title": "FlowNotes",
          "icon": "media/flownotes.png"
        }
      ]
    },
    "views": {
      "flownotes": [
        {
          "type": "webview",
          "id": "flownotes.notesView",
          "name": "Notas"
        }
      ]
    },
    "commands": [
      {
        "command": "flownotes.addNote",
        "title": "FlowNotes: Nueva nota",
        "icon": "$(add)"
      },
      {
        "command": "flownotes.refreshNotes",
        "title": "FlowNotes: Refrescar notas",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "flownotes.addNote",
          "when": "view == flownotes.notesView",
          "group": "navigation"
        },
        {
          "command": "flownotes.refreshNotes",
          "when": "view == flownotes.notesView",
          "group": "navigation@1"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint extension.js test/**/*.js",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.3",
    "jsdom": "^28.1.0"
  },
  "publisher": "ErhartFabian",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tu-user/flownotes.git"
  },
  "icon": "media/flownotes.png"
}
